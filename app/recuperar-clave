<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Restablecer Contraseña | Clínica Dental</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f5f5f5; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        .card { background: white; padding: 40px; border-radius: 20px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); width: 100%; max-width: 400px; text-align: center; }
        h2 { color: #0f4c43; margin-bottom: 10px; } /* Tu color darkGreen */
        p { color: #666; font-size: 14px; margin-bottom: 30px; }
        input { width: 100%; height: 50px; background-color: #F5F5F5; border: none; border-radius: 12px; padding: 0 15px; box-sizing: border-box; margin-bottom: 20px; font-size: 16px; }
        button { width: 100%; height: 50px; background-color: #14b8a6; border: none; border-radius: 12px; color: white; font-weight: bold; font-size: 16px; cursor: pointer; transition: opacity 0.2s; }
        button:hover { opacity: 0.9; }
        .message { margin-top: 20px; font-size: 14px; font-weight: 600; display: none; }
        .success { color: #14b8a6; }
        .error { color: #ef4444; }
    </style>
</head>
<body>

<div class="card">
    <h2>Nueva Contraseña</h2>
    <p>Por favor, ingresa tu nueva clave de acceso para la clínica.</p>
    
    <input type="password" id="newPassword" placeholder="Escribe tu nueva contraseña" required>
    <button id="btnSubmit" onclick="procesarCambioClave()">GUARDAR CONTRASEÑA</button>
    
    <div id="msgBox" class="message"></div>
</div>

<script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
    import { getAuth, verifyPasswordResetCode, confirmPasswordReset } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-auth.js";

    // Reemplaza esto con las credenciales exactas de tu archivo firebase.config
    const firebaseConfig = {
        apiKey: "TU_API_KEY_AQUÍ",
        authDomain: "bbk-app-ffdc0.firebaseapp.com",
        projectId: "bbk-app-ffdc0",
        storageBucket: "bbk-app-ffdc0.appspot.com",
        messagingSenderId: "TU_SENDER_ID",
        appId: "TU_APP_ID"
    };

    const app = initializeApp(firebaseConfig);
    const auth = getAuth(app);

    // Capturamos los parámetros que Firebase inyectó en la URL
    const urlParams = new URLSearchParams(window.location.search);
    const oobCode = urlParams.get('oobCode');

    window.procesarCambioClave = async function() {
        const passwordInput = document.getElementById('newPassword');
        const btnSubmit = document.getElementById('btnSubmit');
        const msgBox = document.getElementById('msgBox');
        
        const nuevaClave = passwordInput.value;

        if (!nuevaClave || nuevaClave.length < 6) {
            mostrarMensaje("La contraseña debe tener al menos 6 caracteres.", "error");
            return;
        }

        if (!oobCode) {
            mostrarMensaje("El código de recuperación no es válido o ha expirado. Solicita un nuevo correo desde la app.", "error");
            return;
        }

        btnSubmit.disabled = true;
        btnSubmit.innerText = "PROCESANDO...";

        try {
            // 1. Verificamos que el código siga siendo válido antes de operar
            await verifyPasswordResetCode(auth, oobCode);
            
            // 2. Confirmamos y aplicamos el cambio de contraseña
            await confirmPasswordReset(auth, oobCode, nuevaClave);

            mostrarMensaje("¡Contraseña actualizada con éxito! Ya puedes regresar a la aplicación e iniciar sesión.", "success");
            passwordInput.style.display = "none";
            btnSubmit.style.display = "none";
        } catch (error) {
            console.error("Error al restablecer clave:", error);
            let mensaje = "No se pudo actualizar la contraseña. El enlace ya fue utilizado o caducó.";
            if (error.code === 'auth/weak-password') {
                mensaje = "La contraseña elegida es muy débil.";
            }
            mostrarMensaje(mensaje, "error");
            btnSubmit.disabled = false;
            btnSubmit.innerText = "GUARDAR CONTRASEÑA";
        }
    }

    function mostrarMensaje(texto, tipo) {
        const msgBox = document.getElementById('msgBox');
        msgBox.innerText = texto;
        msgBox.className = `message ${tipo}`;
        msgBox.style.display = "block";
    }
</script>
</body>
</html>